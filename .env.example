# Copy this file to .env and fill in real values before running the server.

# Long, random, secret string used to sign login tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# How long a login session stays valid.
JWT_EXPIRES_IN=7d

# Port the API server listens on.
PORT=8787

# Comma-separated list of origins allowed to call this API
# (your frontend's URL — e.g. http://localhost:5500 for Live Server,
# or your real domain in production).
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# Seed admin account created on first run (change the password immediately
# after first login — see README).
SEED_ADMIN_EMAIL=admin@sikhjagat.org
SEED_ADMIN_PASSWORD=change-me-immediately
